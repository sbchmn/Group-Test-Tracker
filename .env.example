# Copy to .env and fill values. Never commit real secrets.
SECRET_KEY=your-super-long-random-secret-key-here-generate-with-openssl-rand-hex-32
# DATABASE_URL will be auto-provided by DigitalOcean Postgres component.
# For local dev with Postgres: postgresql://user:pass@localhost:5432/group_tests
# For local SQLite (default fallback): sqlite:///group_tests.db
DATABASE_URL=sqlite:///group_tests.db
FLASK_ENV=development
# Optional admin bootstrap (used by create-admin CLI if provided)
# ADMIN_DEFAULT_PASSWORD=changeme123